{
  "name": "@skillspell/backend",
  "version": "1.0.0",
  "description": "SkillSpell - NestJS Backend",
  "author": "Arnold Simha",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@anthropic-ai/foundry-sdk": "^0.4.0",
    "@anthropic-ai/sdk": "^0.95.0",
    "@google/genai": "^1.52.0",
    "@keyv/redis": "5.1.6",
    "@langfuse/otel": "^5.9.0",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@node-saml/passport-saml": "^5.1.0",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@skillspell/storage-postgres": "*",
    "@socket.io/redis-adapter": "^8.3.0",
    "@strands-agents/sdk": "^1.6.0",
    "archiver": "^7.0.0",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.7.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "keyv": "5.6.0",
    "marked": "^18.0.0",
    "nest-winston": "1.10.2",
    "nestjs-cls": "^6.2.0",
    "nestjs-otel": "^8.0.2",
    "nodemailer": "^8.0.5",
    "openai": "^6.45.0",
    "openid-client": "6.8.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "winston": "3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.27",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/archiver": "^7.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^30.0.0",
    "js-yaml": "^5.2.1",
    "prettier": "^3.9.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)sx?$": [
        "@swc/jest",
        {
          "jsc": {
            "parser": {
              "syntax": "typescript",
              "decorators": true
            },
            "transform": {
              "decoratorMetadata": true
            }
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "^@anthropic-ai/sdk$": "<rootDir>/../__mocks__/@anthropic-ai/sdk.ts",
      "^@strands-agents/sdk/models/anthropic$": "<rootDir>/../__mocks__/@strands-agents/sdk.ts",
      "^@strands-agents/sdk/models/openai$": "<rootDir>/../__mocks__/@strands-agents/sdk.ts",
      "^@strands-agents/sdk/models/google$": "<rootDir>/../__mocks__/@strands-agents/sdk.ts",
      "^@strands-agents/sdk/models/bedrock$": "<rootDir>/../__mocks__/@strands-agents/sdk.ts",
      "^@strands-agents/sdk/vended-plugins/skills$": "<rootDir>/../__mocks__/@strands-agents/sdk/vended-plugins/skills.ts",
      "^@strands-agents/sdk$": "<rootDir>/../__mocks__/@strands-agents/sdk.ts"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!marked/|openid-client/|uuid/)"
    ]
  }
}
