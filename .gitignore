# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Environment
.env
.env.local

# Kubernetes secrets — never commit populated secret manifests.
# Any *secret*.yaml is ignored; *.example.yaml templates are kept (re-included).
k8s/postgres-secret.yaml
k8s/**/*secret*.yaml
!k8s/**/*.example.yaml
*.local

# TypeScript
*.tsbuildinfo

# Test coverage
coverage/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
debug-response-*.txt

# Debug prompt dumps (dev only — generated by DEBUG_DUMP_PROMPTS=true)
debug-prompts/
.claude/worktrees/

# Agent/worktree scratch — never committed
.clone/

# Generated SAML dev key pair — produced by scripts/generate-mock-saml-keys.sh
# Never commit dev credentials; the .gitkeep in docker/saml/ tracks the directory.
docker/saml/mock-saml.crt
.superpowers/

# Local automation scripts — not for CI or code review
.automation/

# graphify scratch output dir (default GRAPHIFY_OUT). The committed knowledge
# graph lives in graph/ — graphify-out/ is regenerable working output.
graphify-out/
# graphify AST/semantic cache — regenerable, not tracked
graph/cache/

# Internal code-review / migration working notes — kept locally, not shipped
.review/
